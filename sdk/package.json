{
  "name": "oxcast-sdk",
  "version": "1.0.1",
  "description": "JavaScript/TypeScript SDK for interacting with 0xCast prediction markets on Stacks",
  "keywords": [
    "stacks",
    "bitcoin",
    "prediction-markets",
    "defi",
    "clarity",
    "blockchain",
    "oxcast",
    "0xcast"
  ],
  "homepage": "https://github.com/mosas2000/0xCast#readme",
  "bugs": {
    "url": "https://github.com/mosas2000/0xCast/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosas2000/0xCast.git",
    "directory": "sdk"
  },
  "license": "MIT",
  "author": "0xCast",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./contracts": {
      "types": "./dist/contracts.d.ts",
      "import": "./dist/contracts.js",
      "require": "./dist/contracts.cjs"
    },
    "./network": {
      "types": "./dist/network.d.ts",
      "import": "./dist/network.js",
      "require": "./dist/network.cjs"
    },
    "./transactions": {
      "types": "./dist/transactions.d.ts",
      "import": "./dist/transactions.js",
      "require": "./dist/transactions.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@stacks/network": ">=6.0.0",
    "@stacks/transactions": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "@stacks/network": {
      "optional": false
    },
    "@stacks/transactions": {
      "optional": false
    }
  },
  "devDependencies": {
    "@stacks/network": "7.3.1",
    "@stacks/transactions": "7.3.1",
    "tsup": "8.5.0",
    "typescript": "5.9.3"
  }
}
