export function getMarketCacheKey(marketId: number): string {
  return `market_${marketId}`;
}

export function getMarketListCacheKey(): string {
  return 'market_list';
}

export function getUserStakeCacheKey(marketId: number, userAddress: string): string {
  return `user_stake_${marketId}_${userAddress}`;
}

export function getUserBalanceCacheKey(userAddress: string): string {
  return `user_balance_${userAddress}`;
}

export function getContractStateCacheKey(): string {
  return 'contract_state';
}

export function getTransactionCacheKey(txId: string): string {
  return `transaction_${txId}`;
}

export function getBlockCacheKey(blockHeight: number): string {
  return `block_${blockHeight}`;
}
