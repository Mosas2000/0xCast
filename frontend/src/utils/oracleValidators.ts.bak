import type { OraclePrice, AggregatedPrice, ProviderHealth } from '@/types/oracle';
import {
  PriceDataValidator as PriceValidator,
  AggregationDataValidator as AggregationValidator,
  ProviderHealthValidator as HealthValidator,
  ConfigurationValidator as ConfigValidator,
  CommonValidators,
} from './validators';

const priceValidator = new PriceValidator();
const aggregationValidator = new AggregationValidator();
const healthValidator = new HealthValidator();
const configValidator = new ConfigValidator();

export class PriceDataValidator {
  static isValidPrice(value: any): boolean {
    return CommonValidators.isValidPositiveNumber(value);
  }

  static isValidTimestamp(timestamp: any): boolean {
    return CommonValidators.isValidTimestamp(timestamp);
  }

  static isValidConfidence(confidence: any): boolean {
    return CommonValidators.isValidRatio(confidence);
  }

  static isValidOraclePrice(price: any): boolean {
    return priceValidator.isValid(price);
  }

  static validatePriceArray(prices: any[]): {
    valid: OraclePrice[];
    invalid: any[];
    errors: string[];
  } {
    return priceValidator.validateArray(prices);
  }

  static sanitizeOraclePrice(price: any): OraclePrice | null {
    return priceValidator.sanitize(price);
  }
}

export class AggregationDataValidator {
  static isValidAggregatedPrice(price: any): boolean {
    return aggregationValidator.isValid(price);
  }

  static validateAggregatedPrice(price: any): {
    valid: boolean;
    errors: string[];
  } {
    return aggregationValidator.validate(price);
  }

  static sanitizeAggregatedPrice(price: any): AggregatedPrice | null {
    return aggregationValidator.sanitize(price);
  }
}

export class ProviderHealthValidator {
  static isValidProviderHealth(health: any): boolean {
    return healthValidator.isValid(health);
  }

  static validateProviderHealth(health: any): {
    valid: boolean;
    errors: string[];
    warnings: string[];
  } {
    return healthValidator.validate(health);
  }

  static sanitizeProviderHealth(health: any): ProviderHealth | null {
    return healthValidator.sanitize(health);
  }
}

export class ConfigurationValidator {
  static isValidMarketId(marketId: any): boolean {
    return ConfigValidator.isValidMarketId(marketId);
  }

  static isValidProviderId(providerId: any): boolean {
    return ConfigValidator.isValidProviderId(providerId);
  }

  static isValidThreshold(threshold: any): boolean {
    return ConfigValidator.isValidThreshold(threshold);
  }

  static isValidTimeframe(timeframe: any): boolean {
    return ConfigValidator.isValidTimeframe(timeframe);
  }

  static validateConfig(config: any): {
    valid: boolean;
    errors: string[];
  } {
    return configValidator.validate(config);
  }
}
