import React, { useState } from 'react';
import type { TechnicalIndicator, IndicatorSettings } from '@/types/charting';

interface IndicatorPanelProps {
  indicators: TechnicalIndicator[];
  onAddIndicator: (type: string) => void;
  onRemoveIndicator: (name: string) => void;
  onToggleIndicator: (name: string) => void;
  onUpdateIndicatorSettings?: (name: string, settings: IndicatorSettings) => void;
}

const AVAILABLE_INDICATORS = [
  { name: 'SMA', label: 'Simple Moving Average', parameters: { period: 20 } },
  { name: 'EMA', label: 'Exponential Moving Average', parameters: { period: 12 } },
  { name: 'RSI', label: 'Relative Strength Index', parameters: { period: 14 } },
  { name: 'MACD', label: 'Moving Average Convergence Divergence', parameters: { fast: 12, slow: 26, signal: 9 } },
  { name: 'Stochastic', label: 'Stochastic Oscillator', parameters: { kPeriod: 14, dPeriod: 3 } },
  { name: 'BBands', label: 'Bollinger Bands', parameters: { period: 20, stdDev: 2 } },
  { name: 'ATR', label: 'Average True Range', parameters: { period: 14 } },
  { name: 'OBV', label: 'On-Balance Volume', parameters: {} },
  { name: 'ADX', label: 'Average Directional Index', parameters: { period: 14 } },
];

export function IndicatorPanel({
  indicators,
  onAddIndicator,
  onRemoveIndicator,
  onToggleIndicator,
  onUpdateIndicatorSettings,
}: IndicatorPanelProps) {
  const [expandedIndicator, setExpandedIndicator] = useState<string | null>(null);

  return (
    <div className="indicator-panel">
      <div className="panel-header">
        <h3>Technical Indicators</h3>
      </div>

      <div className="add-indicator-section">
        <label>Add Indicator:</label>
        <div className="indicator-grid">
          {AVAILABLE_INDICATORS.map(ind => (
            <button
              key={ind.name}
              className="add-indicator-btn"
              onClick={() => onAddIndicator(ind.name)}
              title={ind.label}
            >
              {ind.name}
            </button>
          ))}
        </div>
      </div>

      <div className="indicators-list">
        <h4>Active Indicators ({indicators.length})</h4>
        {indicators.length === 0 ? (
          <p className="no-indicators">No indicators added yet</p>
        ) : (
          indicators.map(indicator => (
            <div key={indicator.name} className="indicator-item">
              <div
                className="indicator-header"
                onClick={() =>
                  setExpandedIndicator(
                    expandedIndicator === indicator.name ? null : indicator.name
                  )
                }
                onKeyDown={(e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); setExpandedIndicator(expandedIndicator === indicator.name ? null : indicator.name); } }}
                role="button"
                tabIndex={0}
                aria-expanded={expandedIndicator === indicator.name}
              >
                <div className="indicator-title">
                  <input
                    type="checkbox"
                    checked={indicator.visible}
                    onChange={() => onToggleIndicator(indicator.name)}
                    className="indicator-toggle"
                  />
                  <span className="indicator-name">{indicator.name}</span>
                  <div
                    className="indicator-color"
                    style={{ backgroundColor: indicator.color }}
                  />
                </div>
                <button
                  className="remove-btn"
                  onClick={e => {
                    e.stopPropagation();
                    onRemoveIndicator(indicator.name);
                  }}
                >
                  ×
                </button>
              </div>

              {expandedIndicator === indicator.name && (
                <div className="indicator-settings">
                  <div className="setting-item">
                    <label>Color:</label>
                    <input
                      type="color"
                      value={indicator.color}
                      onChange={e => {
                        if (onUpdateIndicatorSettings) {
                          onUpdateIndicatorSettings(indicator.name, {
                            name: indicator.name,
                            type: indicator.type,
                            enabled: indicator.visible,
                            parameters: {},
                          });
                        }
                      }}
                    />
                  </div>

                  <div className="setting-item">
                    <label>Type:</label>
                    <select value={indicator.type} disabled>
                      <option value="line">Line</option>
                      <option value="histogram">Histogram</option>
                      <option value="area">Area</option>
                    </select>
                  </div>
                </div>
              )}
            </div>
          ))
        )}
      </div>
    </div>
  );
}

interface IndicatorInfoProps {
  name: string;
  values: Array<{ value: number | number[] | null }>;
}

export function IndicatorInfo({ name, values }: IndicatorInfoProps) {
  const recentValues = values.slice(-5).filter(v => v.value !== null);

  return (
    <div className="indicator-info">
      <h4>{name}</h4>
      <div className="values-list">
        {recentValues.map((v, i) => (
          <div key={i} className="value-item">
            <span className="label">Value {i + 1}:</span>
            <span className="value">
              {Array.isArray(v.value) ? v.value.map(x => x.toFixed(2)).join(', ') : (v.value as number).toFixed(2)}
            </span>
          </div>
        ))}
      </div>
    </div>
  );
}

interface IndicatorComparisonProps {
  indicators: TechnicalIndicator[];
}

export function IndicatorComparison({ indicators }: IndicatorComparisonProps) {
  return (
    <div className="indicator-comparison">
      <h3>Indicator Signals</h3>
      <div className="signals-grid">
        {indicators.map(indicator => {
          const lastValue = indicator.values[indicator.values.length - 1];
          if (!lastValue.value) return null;

          const value = typeof lastValue.value === 'number' ? lastValue.value : lastValue.value[0];

          let signal = 'Neutral';
          let signalClass = '';

          if (indicator.name.includes('RSI')) {
            if (value > 70) {
              signal = 'Overbought';
              signalClass = 'negative';
            } else if (value < 30) {
              signal = 'Oversold';
              signalClass = 'positive';
            }
          } else if (indicator.name === 'MACD' && indicator.type === 'histogram') {
            signal = value > 0 ? 'Bullish' : 'Bearish';
            signalClass = value > 0 ? 'positive' : 'negative';
          }

          return (
            <div key={indicator.name} className={`signal-item ${signalClass}`}>
              <span className="signal-name">{indicator.name}</span>
              <span className="signal-value">{signal}</span>
            </div>
          );
        })}
      </div>
    </div>
  );
}
