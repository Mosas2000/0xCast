import React, { useMemo } from 'react';
import { useRealtimeMarketData, useRealtimeOrderBook, useRealtimeTrades, useRealtimePrice, useRealtimeConnection } from '@/hooks/useRealtimeMarket';
import type { MarketUpdate, OrderBookUpdate, TradeUpdate } from '@/types/websocket';

interface RealtimeMarketCardProps {
  marketId: string;
  showTicker?: boolean;
  showVolume?: boolean;
  showSpread?: boolean;
}

export function RealtimeMarketCard({
  marketId,
  showTicker = true,
  showVolume = true,
  showSpread = true,
}: RealtimeMarketCardProps) {
  const { marketData, isConnected, error } = useRealtimeMarketData(marketId);

  if (error) {
    return (
      <div className="market-card error">
        <div className="error-message">Connection error: {error.message}</div>
      </div>
    );
  }

  return (
    <div className={`market-card ${isConnected ? 'connected' : 'disconnected'}`}>
      <div className="market-card-header">
        <h3>{marketId}</h3>
        <div className="connection-status">
          {isConnected ? <span className="status-connected">Live</span> : <span className="status-disconnected">Offline</span>}
        </div>
      </div>

      {marketData ? (
        <div className="market-card-content">
          <div className="price-section">
            <span className="price-label">Price</span>
            <span className={`price-value ${marketData.change >= 0 ? 'positive' : 'negative'}`}>${marketData.price.toFixed(2)}</span>
            <span className={`price-change ${marketData.change >= 0 ? 'positive' : 'negative'}`}>
              {marketData.change >= 0 ? '+' : ''}
              {marketData.change.toFixed(2)} ({marketData.changePercent.toFixed(2)}%)
            </span>
          </div>

          {showVolume && (
            <div className="volume-section">
              <span className="volume-label">24h Volume</span>
              <span className="volume-value">${marketData.volume.toLocaleString()}</span>
            </div>
          )}

          {showTicker && (
            <div className="ticker-section">
              <span className="ticker-label">Bid</span>
              <span className="ticker-value">${marketData.bid?.toFixed(2)}</span>
              <span className="ticker-label">Ask</span>
              <span className="ticker-value">${marketData.ask?.toFixed(2)}</span>
            </div>
          )}

          {showSpread && marketData.bid && marketData.ask && (
            <div className="spread-section">
              <span className="spread-label">Spread</span>
              <span className="spread-value">
                ${(marketData.ask - marketData.bid).toFixed(4)} ({(((marketData.ask - marketData.bid) / marketData.price) * 100).toFixed(2)}%)
              </span>
            </div>
          )}

          <div className="timestamp">
            Last update: {new Date(marketData.timestamp).toLocaleTimeString()}
          </div>
        </div>
      ) : (
        <div className="loading">Loading market data...</div>
      )}
    </div>
  );
}

interface OrderBookDisplayProps {
  marketId: string;
  maxLevels?: number;
}

export function OrderBookDisplay({ marketId, maxLevels = 10 }: OrderBookDisplayProps) {
  const { orderBook, isLoading } = useRealtimeOrderBook(marketId);

  if (isLoading) {
    return <div className="orderbook-loading">Loading order book...</div>;
  }

  if (!orderBook) {
    return <div className="orderbook-empty">No order book data available</div>;
  }

  const asks = orderBook.asks.slice(0, maxLevels).reverse();
  const bids = orderBook.bids.slice(0, maxLevels);

  return (
    <div className="orderbook">
      <div className="orderbook-header">
        <h3>Order Book - {marketId}</h3>
      </div>

      <div className="orderbook-container">
        <div className="orderbook-side asks">
          <div className="orderbook-title">Asks (Sell)</div>
          <div className="orderbook-rows">
            {asks.map((level, index) => (
              <div key={`ask-${index}`} className="orderbook-row">
                <span className="price">${level.price.toFixed(4)}</span>
                <span className="amount">{level.amount.toFixed(4)}</span>
                <span className="total">${(level.price * level.amount).toFixed(2)}</span>
              </div>
            ))}
          </div>
        </div>

        <div className="orderbook-spread">
          <div className="spread-info">
            {orderBook.asks.length > 0 && orderBook.bids.length > 0 && (
              <>
                <div>Bid: ${orderBook.bids[0].price.toFixed(4)}</div>
                <div>Ask: ${orderBook.asks[0].price.toFixed(4)}</div>
              </>
            )}
          </div>
        </div>

        <div className="orderbook-side bids">
          <div className="orderbook-title">Bids (Buy)</div>
          <div className="orderbook-rows">
            {bids.map((level, index) => (
              <div key={`bid-${index}`} className="orderbook-row">
                <span className="price">${level.price.toFixed(4)}</span>
                <span className="amount">{level.amount.toFixed(4)}</span>
                <span className="total">${(level.price * level.amount).toFixed(2)}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div className="orderbook-info">
        Sequence: {orderBook.sequence} | Updated: {new Date(orderBook.timestamp).toLocaleTimeString()}
      </div>
    </div>
  );
}

interface LiveTradeListProps {
  marketId: string;
  maxTrades?: number;
}

export function LiveTradeList({ marketId, maxTrades = 20 }: LiveTradeListProps) {
  const { trades } = useRealtimeTrades(marketId);

  return (
    <div className="trade-list">
      <div className="trade-list-header">
        <h3>Recent Trades - {marketId}</h3>
        <span className="trade-count">{trades.length} trades</span>
      </div>

      <div className="trade-list-container">
        {trades.length === 0 ? (
          <div className="trade-list-empty">No trades yet</div>
        ) : (
          <div className="trade-rows">
            {trades.slice(0, maxTrades).map((trade, index) => (
              <div key={`${trade.sequence}-${index}`} className={`trade-row ${trade.side}`}>
                <span className="price">${trade.price.toFixed(4)}</span>
                <span className="amount">{trade.amount.toFixed(4)}</span>
                <span className="total">${(trade.price * trade.amount).toFixed(2)}</span>
                <span className="side">{trade.side.toUpperCase()}</span>
                <span className="timestamp">{new Date(trade.timestamp).toLocaleTimeString()}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}

interface WebSocketStatusProps {
  showDetails?: boolean;
}

export function WebSocketStatus({ showDetails = false }: WebSocketStatusProps) {
  const { isConnected, useWebSocket } = useRealtimeConnection();

  return (
    <div className={`ws-status ${isConnected ? 'connected' : 'disconnected'}`}>
      <div className="status-indicator">
        <span className={`indicator ${isConnected ? 'active' : 'inactive'}`}></span>
        <span className="status-text">{isConnected ? 'Connected' : 'Disconnected'}</span>
      </div>

      {showDetails && (
        <div className="status-details">
          <span className="mode">{useWebSocket ? 'WebSocket' : 'Polling'}</span>
        </div>
      )}
    </div>
  );
}

interface MarketPriceTickerProps {
  marketId: string;
  onPriceChange?: (price: number) => void;
}

export function MarketPriceTicker({ marketId, onPriceChange }: MarketPriceTickerProps) {
  const { price, change, changePercent } = useRealtimePrice(marketId);

  React.useEffect(() => {
    if (onPriceChange && price > 0) {
      onPriceChange(price);
    }
  }, [price, onPriceChange]);

  return (
    <div className="price-ticker">
      <div className="ticker-price">${price.toFixed(2)}</div>
      <div className={`ticker-change ${change >= 0 ? 'up' : 'down'}`}>
        {change >= 0 ? '↑' : '↓'} {Math.abs(change).toFixed(2)} ({changePercent.toFixed(2)}%)
      </div>
    </div>
  );
}

interface MarketGridProps {
  marketIds: string[];
  columns?: number;
}

export function MarketGrid({ marketIds, columns = 2 }: MarketGridProps) {
  return (
    <div className="market-grid" style={{ gridTemplateColumns: `repeat(${columns}, 1fr)` }}>
      {marketIds.map((marketId) => (
        <RealtimeMarketCard key={marketId} marketId={marketId} />
      ))}
    </div>
  );
}

interface RealtimeDashboardProps {
  watchlistMarketIds: string[];
  showOrderBook?: boolean;
  showTrades?: boolean;
}

export function RealtimeDashboard({ watchlistMarketIds, showOrderBook = true, showTrades = true }: RealtimeDashboardProps) {
  return (
    <div className="realtime-dashboard">
      <div className="dashboard-header">
        <h2>Market Dashboard</h2>
        <WebSocketStatus showDetails />
      </div>

      <div className="dashboard-content">
        <div className="markets-section">
          <h3>Watchlist ({watchlistMarketIds.length})</h3>
          <MarketGrid marketIds={watchlistMarketIds} columns={2} />
        </div>

        {showOrderBook && watchlistMarketIds.length > 0 && (
          <div className="orderbook-section">
            <OrderBookDisplay marketId={watchlistMarketIds[0]} />
          </div>
        )}

        {showTrades && watchlistMarketIds.length > 0 && (
          <div className="trades-section">
            <LiveTradeList marketId={watchlistMarketIds[0]} />
          </div>
        )}
      </div>
    </div>
  );
}
