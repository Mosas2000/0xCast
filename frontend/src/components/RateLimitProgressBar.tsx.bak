import React from 'react';
import type { RateLimitStatus } from '@/types/rateLimit';
import { calculateRateLimitPercentage, getRateLimitColor } from '@/utils/rateLimitHelpers';

interface RateLimitProgressBarProps {
  status: RateLimitStatus;
  maxRequests: number;
  showLabel?: boolean;
}

export const RateLimitProgressBar: React.FC<RateLimitProgressBarProps> = ({
  status,
  maxRequests,
  showLabel = true,
}) => {
  const percentage = calculateRateLimitPercentage(status, maxRequests);
  const color = getRateLimitColor(status);

  const getColorClass = (): string => {
    switch (color) {
      case 'red':
        return 'bg-red-500';
      case 'yellow':
        return 'bg-yellow-500';
      case 'green':
        return 'bg-green-500';
      default:
        return 'bg-gray-500';
    }
  };

  return (
    <div className="w-full">
      {showLabel && (
        <div className="flex justify-between text-xs mb-1">
          <span>{status.remaining} remaining</span>
          <span>{percentage}%</span>
        </div>
      )}
      <div className="w-full bg-gray-200 rounded-full h-2 overflow-hidden">
        <div
          className={`h-full transition-all duration-300 ${getColorClass()}`}
          style={{ width: `${percentage}%` }}
        />
      </div>
    </div>
  );
};
