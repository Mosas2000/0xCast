import React, { useState } from 'react';
import type { Role, Permission } from '@/types/rbac';
import { RoleHierarchyManager } from '@/services/RoleHierarchyManager';
import { PermissionMatrixManager } from '@/services/PermissionMatrixManager';

interface RoleManagementProps {
  hierarchyManager: RoleHierarchyManager;
  permissionManager: PermissionMatrixManager;
  onRoleUpdate?: (role: Role) => void;
  onRoleDelete?: (roleId: string) => void;
}

export function RoleManagementDashboard({
  hierarchyManager,
  permissionManager,
  onRoleUpdate,
  onRoleDelete,
}: RoleManagementProps) {
  const [roles, setRoles] = useState<Role[]>(Array.from(hierarchyManager.getRoleHierarchy().values()));
  const [selectedRoleId, setSelectedRoleId] = useState<string | null>(null);
  const [showPermissionEditor, setShowPermissionEditor] = useState(false);

  const selectedRole = roles.find(r => r.id === selectedRoleId);

  const handleRoleSelect = (roleId: string) => {
    setSelectedRoleId(roleId);
  };

  const handlePermissionToggle = (permission: Permission) => {
    if (!selectedRole) return;

    const hasPermission = permissionManager.hasPermission(selectedRole.id, permission);

    if (hasPermission) {
      permissionManager.revokePermission(selectedRole.id, permission);
    } else {
      permissionManager.grantPermission(selectedRole.id, permission);
    }

    const updatedPermissions = permissionManager.getRolePermissions(selectedRole.id);
    const updatedRole = { ...selectedRole, permissions: updatedPermissions };

    const updatedRoles = roles.map(r => (r.id === selectedRole.id ? updatedRole : r));
    setRoles(updatedRoles);

    if (onRoleUpdate) {
      onRoleUpdate(updatedRole);
    }
  };

  const getRoleLevel = (roleId: string): number => {
    const role = roles.find(r => r.id === roleId);
    return role?.level ?? -1;
  };

  const sortedRoles = [...roles].sort((a, b) => a.level - b.level);

  return (
    <div className="role-management-container">
      <div className="roles-list">
        <h3>Roles</h3>
        <div className="roles-grid">
          {sortedRoles.map(role => (
            <div
              key={role.id}
              className={`role-card ${selectedRoleId === role.id ? 'selected' : ''}`}
              onClick={() => handleRoleSelect(role.id)}
              onKeyDown={(e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); handleRoleSelect(role.id); } }}
              role="button"
              tabIndex={0}
              aria-pressed={selectedRoleId === role.id}
            >
              <div className="role-header">
                <h4>{role.name}</h4>
                <span className="role-level">Level {role.level}</span>
              </div>
              <p className="role-description">{role.description}</p>
              <div className="role-stats">
                <span className="permission-count">
                  {role.permissions.length} permissions
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>

      {selectedRole && (
        <div className="role-details">
          <div className="role-header-section">
            <h2>{selectedRole.name}</h2>
            <div className="role-metadata">
              <p>
                <strong>Type:</strong> {selectedRole.type}
              </p>
              <p>
                <strong>Level:</strong> {selectedRole.level}
              </p>
              <p>
                <strong>Parent:</strong> {selectedRole.parentRole || 'None'}
              </p>
            </div>
          </div>

          <div className="role-description-section">
            <h3>Description</h3>
            <p>{selectedRole.description}</p>
          </div>

          <div className="permissions-section">
            <div className="permissions-header">
              <h3>Permissions</h3>
              <button
                className="toggle-editor-btn"
                onClick={() => setShowPermissionEditor(!showPermissionEditor)}
              >
                {showPermissionEditor ? 'Done' : 'Edit'}
              </button>
            </div>

            {showPermissionEditor ? (
              <div className="permission-editor">
                <div className="permission-grid">
                  {Object.values(Permission).map(permission => (
                    <div key={permission} className="permission-item">
                      <input
                        type="checkbox"
                        id={`perm-${permission}`}
                        checked={selectedRole.permissions.includes(permission)}
                        onChange={() => handlePermissionToggle(permission)}
                      />
                      <label htmlFor={`perm-${permission}`}>{permission}</label>
                    </div>
                  ))}
                </div>
              </div>
            ) : (
              <div className="permissions-list">
                {selectedRole.permissions.length > 0 ? (
                  <ul>
                    {selectedRole.permissions.map(permission => (
                      <li key={permission} className="permission-badge">
                        {permission}
                      </li>
                    ))}
                  </ul>
                ) : (
                  <p className="no-permissions">No permissions assigned</p>
                )}
              </div>
            )}
          </div>

          <div className="permission-coverage">
            <h3>Permission Coverage</h3>
            <div className="coverage-bar">
              <div
                className="coverage-fill"
                style={{ width: `${permissionManager.getPermissionCoverage(selectedRole.id)}%` }}
              />
            </div>
            <p className="coverage-text">
              {permissionManager.getPermissionCoverage(selectedRole.id).toFixed(1)}% of permissions assigned
            </p>
          </div>

          <div className="role-actions">
            {onRoleDelete && (
              <button
                className="delete-btn"
                onClick={() => {
                  if (confirm('Are you sure you want to delete this role?')) {
                    onRoleDelete(selectedRole.id);
                  }
                }}
              >
                Delete Role
              </button>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
