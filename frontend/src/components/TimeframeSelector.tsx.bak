import React from 'react';
import type { Timeframe } from '@/types/charting';

interface TimeframeSelectorProps {
  currentTimeframe: Timeframe;
  onTimeframeChange: (timeframe: Timeframe) => void;
  disabled?: boolean;
}

const TIMEFRAMES: Timeframe[] = ['1m', '5m', '15m', '30m', '1h', '4h', '1d', '1w', '1M'];

export function TimeframeSelector({
  currentTimeframe,
  onTimeframeChange,
  disabled = false,
}: TimeframeSelectorProps) {
  return (
    <div className="timeframe-selector">
      {TIMEFRAMES.map(tf => (
        <button
          key={tf}
          className={`timeframe-btn ${currentTimeframe === tf ? 'active' : ''}`}
          onClick={() => onTimeframeChange(tf)}
          disabled={disabled}
          title={`Switch to ${tf} timeframe`}
        >
          {tf}
        </button>
      ))}
    </div>
  );
}

interface TimeframeDisplayProps {
  timeframe: Timeframe;
}

export function TimeframeDisplay({ timeframe }: TimeframeDisplayProps) {
  const getTimeframeLabel = (tf: Timeframe): string => {
    const labels: Record<Timeframe, string> = {
      '1m': '1 Minute',
      '5m': '5 Minutes',
      '15m': '15 Minutes',
      '30m': '30 Minutes',
      '1h': '1 Hour',
      '4h': '4 Hours',
      '1d': '1 Day',
      '1w': '1 Week',
      '1M': '1 Month',
    };
    return labels[tf] || tf;
  };

  return (
    <div className="timeframe-display">
      <span className="timeframe-label">{getTimeframeLabel(timeframe)}</span>
    </div>
  );
}

interface TimeframeHistoryProps {
  history: Timeframe[];
  currentTimeframe: Timeframe;
  onTimeframeChange: (timeframe: Timeframe) => void;
  maxHistory?: number;
}

export function TimeframeHistory({
  history,
  currentTimeframe,
  onTimeframeChange,
  maxHistory = 5,
}: TimeframeHistoryProps) {
  const recentTimeframes = Array.from(new Set([currentTimeframe, ...history])).slice(0, maxHistory);

  return (
    <div className="timeframe-history">
      <span className="label">Recent:</span>
      <div className="history-buttons">
        {recentTimeframes.map(tf => (
          <button
            key={tf}
            className={`history-btn ${currentTimeframe === tf ? 'active' : ''}`}
            onClick={() => onTimeframeChange(tf)}
          >
            {tf}
          </button>
        ))}
      </div>
    </div>
  );
}

interface TimeframeComparerProps {
  timeframe1: Timeframe;
  timeframe2: Timeframe;
  onCompare: (tf1: Timeframe, tf2: Timeframe) => void;
}

export function TimeframeComparer({
  timeframe1,
  timeframe2,
  onCompare,
}: TimeframeComparerProps) {
  return (
    <div className="timeframe-comparer">
      <div className="comparer-item">
        <label>Compare with:</label>
        <select
          value={timeframe2}
          onChange={e => onCompare(timeframe1, e.target.value as Timeframe)}
        >
          {TIMEFRAMES.map(tf => (
            <option key={tf} value={tf}>
              {tf}
            </option>
          ))}
        </select>
      </div>
    </div>
  );
}
