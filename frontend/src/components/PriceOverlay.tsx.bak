import React, { useState, useEffect } from 'react';
import type { Candlestick, RealTimeUpdate } from '@/types/charting';

interface PriceOverlayProps {
  currentPrice: number;
  priceChange: number;
  percentChange: number;
  highDay: number;
  lowDay: number;
  lastCandle: Candlestick | null;
  volume24h: number;
}

export function PriceOverlay({
  currentPrice,
  priceChange,
  percentChange,
  highDay,
  lowDay,
  lastCandle,
  volume24h,
}: PriceOverlayProps) {
  const isPositive = priceChange >= 0;

  return (
    <div className="price-overlay">
      <div className="price-section">
        <div className="current-price">
          <span className="label">Price</span>
          <span className={`value ${isPositive ? 'positive' : 'negative'}`}>
            {currentPrice.toFixed(2)}
          </span>
        </div>

        <div className="price-change">
          <span className={`change ${isPositive ? 'positive' : 'negative'}`}>
            {isPositive ? '+' : ''}{priceChange.toFixed(2)} ({percentChange.toFixed(2)}%)
          </span>
        </div>
      </div>

      <div className="ohlc-section">
        <div className="ohlc-value">
          <span className="label">O</span>
          <span className="value">{lastCandle?.open.toFixed(2)}</span>
        </div>
        <div className="ohlc-value">
          <span className="label">H</span>
          <span className="value">{highDay.toFixed(2)}</span>
        </div>
        <div className="ohlc-value">
          <span className="label">L</span>
          <span className="value">{lowDay.toFixed(2)}</span>
        </div>
        <div className="ohlc-value">
          <span className="label">C</span>
          <span className="value">{lastCandle?.close.toFixed(2)}</span>
        </div>
      </div>

      <div className="volume-section">
        <span className="label">Volume</span>
        <span className="value">{(volume24h / 1000000).toFixed(2)}M</span>
      </div>
    </div>
  );
}

interface RealTimeTickerProps {
  updates: RealTimeUpdate[];
  maxItems?: number;
}

export function RealTimeTicker({ updates, maxItems = 5 }: RealTimeTickerProps) {
  return (
    <div className="real-time-ticker">
      <h4>Real-Time Updates</h4>
      <div className="ticker-list">
        {updates.slice(-maxItems).map((update, index) => {
          const isPositive = update.percentChange >= 0;
          return (
            <div key={index} className="ticker-item">
              <div className="ticker-market">{update.marketId}</div>
              <div className={`ticker-price ${isPositive ? 'positive' : 'negative'}`}>
                {update.currentPrice.toFixed(2)}
              </div>
              <div className={`ticker-change ${isPositive ? 'positive' : 'negative'}`}>
                {isPositive ? '+' : ''}{update.percentChange.toFixed(2)}%
              </div>
              <div className="ticker-time">
                {new Date(update.timestamp).toLocaleTimeString()}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}

interface PriceLevelLineProps {
  price: number;
  label: string;
  color: string;
  dashStyle?: 'solid' | 'dashed' | 'dotted';
}

export function PriceLevelLine({
  price,
  label,
  color,
  dashStyle = 'dashed',
}: PriceLevelLineProps) {
  const getDashPattern = () => {
    switch (dashStyle) {
      case 'dashed':
        return [5, 5];
      case 'dotted':
        return [2, 2];
      default:
        return [];
    }
  };

  return (
    <div
      className="price-level-line"
      style={{
        borderTopColor: color,
        borderTopStyle: dashStyle,
        borderTopWidth: '1px',
      }}
    >
      <span className="price-label" style={{ color }}>
        {label}
      </span>
    </div>
  );
}

interface VolumeSpikeAlertProps {
  currentVolume: number;
  averageVolume: number;
  threshold?: number;
}

export function VolumeSpikeAlert({
  currentVolume,
  averageVolume,
  threshold = 2,
}: VolumeSpikeAlertProps) {
  const ratio = currentVolume / averageVolume;
  const isSpike = ratio > threshold;

  if (!isSpike) return null;

  return (
    <div className="volume-spike-alert">
      <div className="alert-content">
        <span className="alert-icon">⚠️</span>
        <span className="alert-text">
          High Volume: {ratio.toFixed(1)}x average ({(currentVolume / 1000000).toFixed(2)}M)
        </span>
      </div>
    </div>
  );
}
