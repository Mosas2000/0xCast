    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.6",
    "idb": "^8.0.3",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "toml": "^3.0.0"
