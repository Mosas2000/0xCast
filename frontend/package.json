{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --cache",
    "lint:no-cache": "eslint .",
    "lint:fix": "eslint . --cache --fix",
    "lint:profile": "node scripts/eslint-profile.js",
    "lint:clear-cache": "rm -f .eslintcache",
